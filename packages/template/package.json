{
  "name": "template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Vue 3 + TypeScript + Element Plus admin application (the scaffold template).",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run --passWithNoTests && playwright test",
    "test:unit": "vitest run --passWithNoTests",
    "test:e2e": "playwright test"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@vueuse/core": "^14.3.0",
    "axios": "^1.18.1",
    "element-plus": "^2.14.3",
    "js-cookie": "^3.0.8",
    "nprogress": "^0.2.0",
    "path-browserify": "^1.0.1",
    "pinia": "^2.3.1",
    "vue": "^3.4.0",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^20.0.0",
    "@types/nprogress": "^0.2.3",
    "@types/path-browserify": "^1.0.3",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.5.0",
    "jsdom": "^24.0.0",
    "mockjs": "^1.1.0",
    "sass": "^1.101.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-mock": "^3.0.2",
    "vitest": "^1.0.0",
    "vue-tsc": "^2.2.12"
  },
  "license": "MIT"
}
